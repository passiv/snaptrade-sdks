{
  "name": "snaptrade-typescript-sdk",
  "version": "9.0.191",
  "description": "Client for SnapTrade",
  "author": "Konfig",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/passiv/snaptrade-sdks.git",
    "directory": "sdks/typescript"
  },
  "homepage": "https://github.com/passiv/snaptrade-sdks/tree/HEAD/sdks/typescript#readme",
  "keywords": [
    "axios",
    "typescript",
    "konfig",
    "snaptrade-typescript-sdk"
  ],
  "license": "Unlicense",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "./dist/**/*"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsdown",
    "prepack": "node ./scripts/sync-version.mjs && npm run build",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "1.14.0"
  },
  "resolutions": {
    "semver": "^7.5.2",
    "@babel/traverse": "^7.23.2"
  },
  "devDependencies": {
    "@jest/types": "^29.6.3",
    "@types/jest": "^29.2.4",
    "@types/node": "^20",
    "jest": "^29.3.1",
    "ts-jest": "^29.0.3",
    "ts-node": "^10.9.1",
    "tsdown": "^0.21.10",
    "typescript": "^5.4.0",
    "yaml": "^2.4.0"
  }
}
